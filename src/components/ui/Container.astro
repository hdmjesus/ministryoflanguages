---
/**
 * Centered content container. Single source of truth for the page's
 * max width and horizontal padding so every section lines up.
 */
interface Props {
  as?: "div" | "section" | "header" | "footer"
  class?: string
}

const { as: Tag = "div", class: className = "" } = Astro.props
---

<Tag class={`mx-auto w-full max-w-6xl px-4 ${className}`}>
  <slot />
</Tag>

---
/** Generic white surface card (class tiles, sign-in form). */
interface Props {
  as?: "div" | "li" | "article" | "form"
  class?: string
}

const { as: Tag = "div", class: className = "" } = Astro.props
---

<Tag class={`rounded-xl border border-border bg-card shadow-sm ${className}`}>
  <slot />
</Tag>

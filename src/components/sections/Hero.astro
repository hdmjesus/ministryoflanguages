---
import { site, leftInfo, rightInfo } from "@/data/site"
import Container from "@/components/ui/Container.astro"
import InfoColumn from "@/components/sections/InfoColumn.astro"
import Button from "@/components/ui/Button.astro"
import Logo from "@/components/ui/Logo.astro"
---

<section id="top" class="bg-background">
  <Container class="py-12 md:py-20">
    <div class="grid items-center gap-10 md:grid-cols-[minmax(0,1fr)_minmax(300px,380px)_minmax(0,1fr)] md:gap-8 lg:grid-cols-[minmax(0,1fr)_minmax(340px,430px)_minmax(0,1fr)]">
      <div class="order-2 md:order-1">
        <InfoColumn heading="Info" items={leftInfo} />
      </div>

      <div class="order-1 mx-auto flex max-w-md flex-col items-center text-center md:order-2">
        <Logo class="h-28 w-28 md:h-36 md:w-36 lg:h-40 lg:w-40" />
        <p
          class="mt-6 font-heading text-xs font-semibold uppercase tracking-[0.25em] text-muted-foreground"
        >
          {site.shortName}
        </p>
        <h1
          class="mt-3 text-balance font-heading text-3xl font-extrabold leading-tight text-primary md:text-[2rem] lg:text-4xl"
        >
          {site.heroTitle}
        </h1>
        <p class="mt-3 max-w-sm text-pretty leading-relaxed text-muted-foreground">
          {site.subtitle}
        </p>
        <Button href="#signin" class="mt-6">Register Now</Button>
        <p
          class="mt-4 font-heading text-xs font-semibold uppercase tracking-[0.25em] text-muted-foreground"
        >
          {site.tagline}
        </p>
      </div>

      <div class="order-3">
        <InfoColumn heading="Info" items={rightInfo} />
      </div>
    </div>
  </Container>
</section>

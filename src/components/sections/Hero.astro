---
import { site, leftInfo, rightInfo } from "@/data/site"
import Container from "@/components/ui/Container.astro"
import InfoColumn from "@/components/sections/InfoColumn.astro"
import Button from "@/components/ui/Button.astro"
import Logo from "@/components/ui/Logo.astro"
---

<section id="top" class="bg-background">
  <Container class="py-12 md:py-20">
    <div class="grid items-center gap-10 md:grid-cols-[1fr_auto_1fr] md:gap-8">
      <div class="order-2 md:order-1">
        <InfoColumn heading="Info" items={leftInfo} />
      </div>

      <div class="order-1 flex flex-col items-center text-center md:order-2">
        <Logo class="h-40 w-40 md:h-52 md:w-52" />
        <p
          class="mt-6 font-heading text-xs font-semibold uppercase tracking-[0.25em] text-muted-foreground"
        >
          {site.shortName}
        </p>
        <h1
          class="mt-3 text-balance font-heading text-3xl font-extrabold leading-tight text-primary md:text-4xl"
        >
          {site.heroTitle}
        </h1>
        <p class="mt-3 max-w-md text-pretty leading-relaxed text-muted-foreground">
          {site.subtitle}
        </p>
        <Button href="#signin" class="mt-6">Register Now</Button>
        <p
          class="mt-4 font-heading text-xs font-semibold uppercase tracking-[0.25em] text-muted-foreground"
        >
          {site.tagline}
        </p>
      </div>

      <div class="order-3">
        <InfoColumn heading="Info" items={rightInfo} />
      </div>
    </div>
  </Container>
</section>

---
import { Icon } from "astro-icon/components"
import type { InfoItem } from "@/data/site"

interface Props {
  heading: string
  items: InfoItem[]
}

const { heading, items } = Astro.props
---

<div class="flex flex-col gap-5">
  <h2 class="font-heading text-xs font-bold uppercase tracking-[0.2em] text-accent">
    {heading}
  </h2>
  <ul class="flex flex-col gap-5">
    {
      items.map((item) => (
        <li class="flex gap-3">
          <span class="mt-0.5 flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-accent/15 text-foreground">
            <Icon name={item.icon} class="h-5 w-5" />
          </span>
          <div>
            <p class="font-heading text-sm font-semibold text-foreground">{item.title}</p>
            <p class="text-sm leading-relaxed text-muted-foreground">{item.text}</p>
          </div>
        </li>
      ))
    }
  </ul>
</div>

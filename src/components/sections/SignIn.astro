---
import { languages } from "@/data/site"
import Container from "@/components/ui/Container.astro"
import Card from "@/components/ui/Card.astro"
import Field from "@/components/ui/Field.astro"
import Button from "@/components/ui/Button.astro"

const emailJsPublicKey = import.meta.env.PUBLIC_EMAILJS_PUBLIC_KEY ?? ""
const emailJsServiceId = import.meta.env.PUBLIC_EMAILJS_SERVICE_ID ?? ""
const emailJsTemplateId = import.meta.env.PUBLIC_EMAILJS_TEMPLATE_ID ?? ""
---

<section id="signin" class="bg-surface text-surface-foreground scroll-mt-20">
  <Container class="grid items-center gap-10 py-16 md:grid-cols-2 md:py-20 lg:gap-16">
    <div>
      <p class="font-heading text-xs font-bold uppercase tracking-[0.25em] text-surface-accent">
        Sign-In
      </p>

      <h2 class="mt-4 text-balance font-heading text-3xl font-extrabold leading-tight md:text-4xl">
        Reserve your seat<br class="hidden sm:block" /> in the next group
      </h2>

      <p class="mt-5 max-w-md text-pretty leading-relaxed text-surface-foreground/80">
        Tell us which language you want to learn and we'll send you the schedule and joining details
        for the live online classes.
      </p>
    </div>

    <Card class="p-6 md:p-8">
  <form id="signin-form" class="flex flex-col gap-5">
    <Field label="Full name" name="name" placeholder="Your name" required />
    <Field label="Email" name="email" type="email" placeholder="you@example.com" required />
    <Field label="Select a language" name="language" options={languages} required />

    <Button type="submit" class="mt-1 w-full">Send</Button>

    <p
      id="signin-status"
      class="min-h-5 text-sm text-surface-foreground/70"
      aria-live="polite"
    ></p>
  </form>
</Card>
  </Container>
</section>

<script
  is:inline
  src="https://cdn.jsdelivr.net/npm/@emailjs/browser@4/dist/email.min.js"
></script>
<script
  is:inline
  src="https://cdn.jsdelivr.net/npm/@emailjs/browser@4/dist/email.min.js"
></script>

<script is:inline define:vars={{ emailJsPublicKey, emailJsServiceId, emailJsTemplateId }}>
  window.addEventListener("load", () => {
    const form = document.getElementById("signin-form")
    const status = document.getElementById("signin-status")

    console.log({
      form,
      status,
      emailjs: window.emailjs,
      emailJsPublicKey,
      emailJsServiceId,
      emailJsTemplateId,
    })

    if (!(form instanceof HTMLFormElement)) {
      console.error("signin-form is not a real form")
      return
    }

    window.emailjs.init({
      publicKey: emailJsPublicKey,
    })

    form.addEventListener("submit", async (event) => {
      event.preventDefault()

      status.textContent = "Sending..."

      try {
        const result = await window.emailjs.sendForm(
          emailJsServiceId,
          emailJsTemplateId,
          form
        )

        console.log("EmailJS success:", result)
        form.reset()
        status.textContent = "Sent successfully."
        status.className = "min-h-5 text-sm text-green-700"
      } catch (error) {
        console.error("EmailJS error:", error)
        status.textContent = error?.text || error?.message || "Error sending email."
        status.className = "min-h-5 text-sm text-red-600"
      }
    })
  })
</script>
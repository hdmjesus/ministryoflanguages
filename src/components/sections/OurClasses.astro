---
import { courseLanguages } from "@/data/site"
import { useTranslations } from "@/i18n"
import Container from "@/components/ui/Container.astro"

const t = useTranslations(Astro.currentLocale)

// courseLanguages index aligns with t.languageNames order.
const cards = t.languageNames.map((name, i) => ({ name, ...courseLanguages[i] }))
---

<section id="classes" class="bg-background scroll-mt-20">
  <Container class="py-16 md:py-20">
    <div class="flex flex-col items-center text-center">
      <h2 class="font-heading text-3xl font-extrabold text-primary md:text-4xl">
        {t.classesHeading}
      </h2>
      <p class="mt-3 max-w-xl text-pretty leading-relaxed text-muted-foreground">
        {t.classesSubtitle}
      </p>
    </div>

    <ul
      id="languages"
      class="mt-12 grid gap-6 scroll-mt-20 sm:grid-cols-2 lg:grid-cols-4"
    >
      {
        cards.map((lang) => (
          <li class="group relative overflow-hidden rounded-2xl border border-border bg-card shadow-sm transition-all duration-300 hover:-translate-y-1 hover:border-accent hover:shadow-xl">
            {/* top accent band */}
            <div class="h-1.5 w-full bg-linear-to-r from-primary via-accent to-primary" />

            <div class="flex flex-col items-center gap-4 px-6 py-8 text-center">
              <span class="flex h-20 w-20 items-center justify-center rounded-2xl bg-primary/5 text-5xl leading-none shadow-inner ring-1 ring-border transition-transform duration-300 group-hover:scale-110">
                {lang.flag}
              </span>

              <h3 class="font-heading text-lg font-bold text-foreground">
                {lang.name}
              </h3>

              <ul class="flex flex-wrap items-center justify-center gap-2">
                {lang.levels.map((level) => (
                  <li class="rounded-full bg-accent/15 px-3 py-1 font-heading text-xs font-bold uppercase tracking-wide text-accent transition-colors group-hover:bg-accent group-hover:text-accent-foreground">
                    {level}
                  </li>
                ))}
              </ul>
            </div>
          </li>
        ))
      }
    </ul>
  </Container>
</section>

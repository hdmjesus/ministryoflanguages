---
import { classes } from "@/data/site"
import { useTranslations } from "@/i18n"
import Container from "@/components/ui/Container.astro"
import Card from "@/components/ui/Card.astro"

const t = useTranslations(Astro.currentLocale)
---

<section id="classes" class="bg-background scroll-mt-20">
  <Container class="py-16 md:py-20">
    <div class="flex flex-col items-center text-center">
      <h2 class="font-heading text-3xl font-extrabold text-primary md:text-4xl">{t.classesHeading}</h2>
      <p class="mt-3 max-w-xl text-pretty leading-relaxed text-muted-foreground">
        {t.classesSubtitle}
      </p>
    </div>

    <ul id="languages" class="mt-10 grid gap-5 scroll-mt-20 sm:grid-cols-2 lg:grid-cols-3">
      {
        classes.map((item) => (
          <Card
            as="li"
            class="flex items-center gap-4 p-5 transition-colors hover:border-accent"
          >
            <span class="flex h-12 w-12 shrink-0 items-center justify-center rounded-lg bg-primary font-heading text-sm font-bold text-primary-foreground">
              {item.flag}
            </span>
            <div>
              <p class="font-heading text-base font-semibold text-foreground">{item.name}</p>
              <p class="text-sm text-muted-foreground">{t.levels[item.levelKey]}</p>
            </div>
          </Card>
        ))
      }
    </ul>
  </Container>
</section>

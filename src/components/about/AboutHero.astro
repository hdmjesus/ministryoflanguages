---
import { useTranslations } from "@/i18n";

const { hero } = useTranslations(Astro.currentLocale).aboutPage;
const statNums = ["7", "100%", "20+"];
---

<header class="hero">
  <div class="hero__inner">
    <h1 class="hero__title">
      {hero.line1}<br />
      {hero.line2}<br />
      <span class="accent">{hero.line3}</span>
    </h1>
    <p class="hero__lead">{hero.lead}</p>
    <div class="hero__stats">
      {
        hero.statLabels.map((label, i) => (
          <div class="stat">
            <span class="stat__num">{statNums[i]}</span>
            <span class="stat__label">{label}</span>
          </div>
        ))
      }
    </div>
  </div>
</header>

<style>
  .hero {
    background:
      radial-gradient(1200px 500px at 80% -10%, rgba(232, 163, 23, 0.18), transparent 60%),
      linear-gradient(180deg, #0a1c44 0%, #0d2050 100%);
    padding: 60px 24px 84px;
    position: relative;
    overflow: hidden;
  }

  .hero__inner {
    max-width: 900px;
    margin: 0 auto;
    text-align: center;
  }

  .hero .eyebrow {
    margin-bottom: 18px;
  }

  .hero__title {
    color: #ffffff;
    font-size: clamp(2.1rem, 5vw, 3.4rem);
  }

  .hero__title .accent {
    color: var(--gold-soft);
  }

  .hero__lead {
    color: #c6d2ea;
    font-size: 1.08rem;
    max-width: 680px;
    margin: 22px auto 0;
  }

  .hero__stats {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 20px;
    margin-top: 40px;
  }

  .stat {
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 16px;
    padding: 18px 28px;
    min-width: 150px;
  }

  .stat__num {
    display: block;
    font-family: "Poppins", sans-serif;
    font-weight: 800;
    font-size: 1.9rem;
    color: var(--gold-soft);
    line-height: 1;
  }

  .stat__label {
    display: block;
    margin-top: 6px;
    font-size: 0.85rem;
    color: #c6d2ea;
  }

  @media (max-width: 520px) {
    .hero {
      padding: 72px 20px 64px;
    }
  }
</style>

---
// Nuestra Promesa / CTA
import { useTranslations } from "@/i18n";

const { promise } = useTranslations(Astro.currentLocale).aboutPage;
---

<div class="promise">
  <span class="kicker">{promise.kicker}</span>
  <h2>{promise.title}</h2>
  <p>{promise.text}</p>
  <div class="promise__actions">
    <a class="btn btn--primary" href="/#classes">{promise.seeClasses}</a>
    <a class="btn btn--ghost" href="/#pricing">{promise.seePricing}</a>
  </div>
</div>

<style>
  .promise {
    margin: 84px auto 96px;
    text-align: center;
    max-width: 720px;
  }

  .promise h2 {
    font-size: clamp(1.6rem, 3vw, 2.1rem);
    margin: 8px 0 14px;
  }

  .promise__actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 14px;
    margin-top: 26px;
  }
</style>
